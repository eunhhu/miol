// =====================================================
// 09-shopping-mall.orv — 북극성 벤치마크 (MVP 검증용)
// =====================================================
//
// "비개발자가 AI 없이 5시간 만에 쇼핑몰을 만든다" 목표를 검증하기 위한
// **현재 구현된 언어 기능만** 사용한 축소판. 실제 서버/DB는 아직 구현
// 전이므로, 이 fixture는 인메모리 tree-walker 인터프리터로 동작한다.
//
// 범위 (Commit 1~20 기반):
//   - struct, 배열, 객체, let/mut/sig, 함수/람다, if/when, for/while,
//     try/catch, 문자열 보간, 배열 메서드 map/filter/reduce
//
// 범위 밖 (장래 커밋에서 확장):
//   - @route/@db/@html 등 도메인 — 인터프리터가 아직 미지원
//   - 실제 서버 바이너리/클라이언트 WASM 분리

// ----- 데이터 모델 -----

struct Product {
  id: int
  name: string
  price: int
  stock: int
}

struct CartItem {
  productId: int
  quantity: int
}

struct OrderLine {
  name: string
  price: int
  quantity: int
  subtotal: int
}

struct Order {
  orderId: int
  lines: OrderLine[]
  total: int
  status: string
}

// ----- 인벤토리 -----

let catalog: Product[] = [
  { id: 1, name: "Kettle", price: 25000, stock: 10 },
  { id: 2, name: "Mug", price: 8000, stock: 50 },
  { id: 3, name: "Tea Set", price: 42000, stock: 3 },
  { id: 4, name: "Cookie Box", price: 12000, stock: 25 }
]

function findProduct(id: int): Product -> {
  let mut found: Product = catalog[0]
  let mut matched: bool = false
  for i in 0..catalog.length {
    if catalog[i].id == id {
      found = catalog[i]
      matched = true
    }
  }
  if !matched {
    throw { code: "not_found", msg: "product {id} missing" }
  }
  found
}

// ----- 장바구니 -----

function cartTotal(cart: CartItem[]): int -> {
  cart
    .map((item) -> {
      let p: Product = findProduct(item.productId)
      p.price * item.quantity
    })
    .reduce(0, (acc, x) -> acc + x)
}

function cartLines(cart: CartItem[]): OrderLine[] -> {
  cart.map((item) -> {
    let p: Product = findProduct(item.productId)
    {
      name: p.name,
      price: p.price,
      quantity: item.quantity,
      subtotal: p.price * item.quantity
    }
  })
}

// ----- 결제 -----

function formatMoney(amount: int): string -> "{amount / 1000}.{amount % 1000} KRW"

function processOrder(cart: CartItem[], paid: int): Order -> {
  let total: int = cartTotal(cart)
  if paid < total {
    throw { code: "insufficient", msg: "paid {paid} < total {total}" }
  }
  {
    orderId: 1001,
    lines: cartLines(cart),
    total: total,
    status: "paid"
  }
}

function printReceipt(order: Order) -> {
  @out "=================="
  @out "Order #{order.orderId}"
  @out "------------------"
  for i in 0..order.lines.length {
    let line: OrderLine = order.lines[i]
    @out "{line.name} x{line.quantity}  {formatMoney(line.subtotal)}"
  }
  @out "------------------"
  @out "TOTAL: {formatMoney(order.total)}"
  @out "STATUS: {order.status}"
  @out "=================="
}

// ----- 메인 플로우 -----

@out "== Orv Shopping Mall =="

// 1) 카탈로그 표시
@out ""
@out "[Catalog]"
let listing: string[] = catalog.map((p) -> "  #{p.id} {p.name} — {formatMoney(p.price)} (stock {p.stock})")
for i in 0..listing.length {
  @out listing[i]
}

// 2) 장바구니 담기
let cart: CartItem[] = [
  { productId: 1, quantity: 1 },
  { productId: 2, quantity: 3 },
  { productId: 4, quantity: 2 }
]

@out ""
@out "[Cart preview]"
@out "items: {cart.length}, total: {formatMoney(cartTotal(cart))}"

// 3) 결제 성공 케이스
@out ""
try {
  let order: Order = processOrder(cart, 100000)
  printReceipt(order)
} catch err {
  @out "payment failed: {err.msg}"
}

// 4) 결제 실패 케이스 (try/catch 검증)
@out ""
try {
  let order: Order = processOrder(cart, 10000)
  printReceipt(order)
} catch err {
  @out "payment failed ({err.code}): {err.msg}"
}

// 5) 재고 상위 3개 추천 (filter + sort-like via reduce)
@out ""
@out "[Recommendations — most stocked]"
let topNames: string[] = catalog
  .filter((p) -> p.stock >= 10)
  .map((p) -> "  {p.name} (stock {p.stock})")
for i in 0..topNames.length {
  @out topNames[i]
}

@out ""
@out "== Done =="
