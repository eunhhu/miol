// =====================================================
// e2e/shopping_mall.orv — minimal catalog + order flow
// =====================================================
//
// This fixture is the first HTTP/DB vertical slice for the shopping-mall
// north-star: product CRUD surface, JSON/form request bodies, route params,
// browser starter forms, and restart-safe reference persistence through the
// shared SQLite-backed DB.

@server {
  @listen 0
  let shopdb = @db.connect(@env.SHOP_DATABASE_URL ?? "sqlite://data/shop.sqlite")
  let adminMember = await shopdb.find("Member", { handle: "admin" })
  if adminMember == void {
    await shopdb.create("Member", {
      handle: "admin",
      name: "Admin",
      email: "admin@example.test",
      role: "admin"
    })
  }

  @route GET /health {
    @respond 200 { ok: true, service: "shopping" }
  }

  @route GET / {
    @serve @html {
      @body {
        @h1 "Miol Shop"
        @p "Catalog, member signup, payment capture, and shipment booking are ready."
        @nav {
          @a href="/catalog" "Shop catalog"
          @a href="/cart" "Cart"
          @a href="/account/sessions" "My sessions"
          @a href="/admin" "Admin dashboard"
        }
        @section {
          class="shop-actions"
          @h2 "Browser checkout forms"
          @form action="/products" method=post {
            @h3 "Add product"
            @input type=hidden name=_csrf value="orv-reference-csrf"
            @label "SKU"
            @input type=text name=sku required
            @label "Name"
            @input type=text name=name required
            @label "Price"
            @input type=number name=price required
            @label "Stock"
            @input type=number name=stock required
            @button type=submit "Create product"
          }
          @form action="/members" method=post {
            @h3 "Join member"
            @input type=hidden name=_csrf value="orv-reference-csrf"
            @label "Handle"
            @input type=text name=handle required
            @label "Name"
            @input type=text name=name required
            @label "Email"
            @input type=email name=email required
            @button type=submit "Create member"
          }
          @form action="/members/login" method=post {
            @h3 "Member login"
            @input type=hidden name=_csrf value="orv-reference-csrf"
            @label "Handle"
            @input type=text name=handle required
            @label "Email"
            @input type=email name=email required
            @button type=submit "Create session"
          }
          @form action="/orders" method=post {
            @h3 "Reserve order"
            @input type=hidden name=_csrf value="orv-reference-csrf"
            @label "Customer"
            @input type=text name=customer required
            @label "SKU"
            @input type=text name=sku required
            @label "Quantity"
            @input type=number name=quantity required
            @label "Total"
            @input type=number name=total required
            @button type=submit "Reserve order"
          }
          @form action="/checkout" method=post {
            @h3 "One-step checkout"
            @input type=hidden name=_csrf value="orv-reference-csrf"
            @label "Member handle"
            @input type=text name=handle required
            @label "SKU"
            @input type=text name=sku required
            @label "Quantity"
            @input type=number name=quantity required
            @label "Total"
            @input type=number name=total required
            @label "Method"
            @input type=text name=method value=card required
            @label "Carrier"
            @input type=text name=carrier value=post required
            @label "Address"
            @input type=text name=address required
            @button type=submit "Checkout"
          }
          @form action="/cart/items" method=post {
            @h3 "Add to cart"
            @input type=hidden name=_csrf value="orv-reference-csrf"
            @label "Member handle"
            @input type=text name=handle required
            @label "SKU"
            @input type=text name=sku required
            @label "Quantity"
            @input type=number name=quantity required
            @button type=submit "Add item"
          }
          @form action="/payments" method=post {
            @h3 "Capture payment"
            @input type=hidden name=_csrf value="orv-reference-csrf"
            @label "Order ID"
            @input type=number name=orderId required
            @label "Amount"
            @input type=number name=amount required
            @label "Method"
            @input type=text name=method value=card required
            @button type=submit "Capture payment"
          }
          @form action="/webhooks/stripe" method=post {
            @h3 "Stripe webhook"
            @label "Payload"
            @input type=text name=payload value=evt_1 required
            @button type=submit "Record webhook"
          }
          @form action="/shipments" method=post {
            @h3 "Book shipment"
            @input type=hidden name=_csrf value="orv-reference-csrf"
            @label "Order ID"
            @input type=number name=orderId required
            @label "Carrier"
            @input type=text name=carrier value=post required
            @label "Address"
            @input type=text name=address required
            @button type=submit "Book shipment"
          }
        }
        @ul {
          @li "POST /products"
          @li "POST /members"
          @li "POST /members/login"
          @li "POST /orders"
          @li "POST /checkout"
          @li "POST /cart/items"
          @li "POST /payments"
          @li "POST /webhooks/stripe"
          @li "POST /shipments"
        }
      }
    }
  }

  @route GET /admin {
    @Auth required role="admin"
    @serve @html {
      @body {
        @h1 "Miol Shop Admin"
        @p "Operations dashboard for catalog, members, orders, payments, shipments, and persistent records."
        @section {
          class="admin-dashboard"
          @h2 "Read models"
          @ul {
            @li { @a href="/admin/catalog" "Catalog read model" }
            @li { @a href="/admin/summary" "Operations summary" }
            @li { @a href="/admin/orders" "Order read model" }
            @li { @a href="/admin/payments" "Payment read model" }
            @li { @a href="/admin/shipments" "Shipment read model" }
            @li { @a href="/admin/webhooks" "Webhook read model" }
            @li { @a href="/admin/audit" "Audit read model" }
            @li { @a href="/products" "Catalog API" }
            @li { @a href="/orders/demo" "Orders by customer" }
            @li { @a href="/shipments/1" "Shipment lookup" }
            @li "Stripe webhook events: POST /webhooks/stripe"
          }
        }
        @section {
          class="admin-storage"
          @h2 "Persistent storage"
          @ul {
            @li "SQLite database: data/shop.sqlite"
            @li "Payment records: data/payments.jsonl"
            @li "Shipment records: data/shipments.jsonl"
            @li "Webhook events: WebhookEvent rows"
            @li "Audit events: AuditEvent rows"
          }
        }
      }
    }
  }

  @route GET /admin/summary {
    @Auth required role="admin"
    let products = await shopdb.count("Product", {})
    let members = await shopdb.count("Member", {})
    let orders = await shopdb.count("Order", {})
    let payments = await shopdb.count("Payment", {})
    let shipments = await shopdb.count("Shipment", {})
    let webhookEvents = await shopdb.count("WebhookEvent", {})
    let auditEvents = await shopdb.count("AuditEvent", {})
    @respond 200 {
      products: products,
      members: members,
      orders: orders,
      payments: payments,
      shipments: shipments,
      webhookEvents: webhookEvents,
      auditEvents: auditEvents
    }
  }

  @route GET /admin/catalog {
    @Auth required role="admin"
    let products = await shopdb.findAll("Product", {})
    @serve @html {
      @body {
        @h1 "Catalog"
        @ul {
          for product in products {
            @li "{product.sku}: {product.name} / stock {product.stock}"
          }
        }
      }
    }
  }

  @route GET /catalog {
    let products = await shopdb.findAll("Product", {})
    @serve @html {
      @body {
        @h1 "Shop Catalog"
        @ul {
          for product in products {
            @li "{product.name} ({product.sku}) / price {product.price} / stock {product.stock}"
          }
        }
      }
    }
  }

  @route GET /account/sessions {
    @session required
    let sessionId: int = @session.id as int
    let sessions = await shopdb.findAll("Session", { id: sessionId })
    @serve @html {
      @body {
        @h1 "Account Sessions"
        @ul {
          for session in sessions {
            @li "{session.handle} / {session.status}"
          }
        }
      }
    }
  }

  @route GET /cart {
    let items = await shopdb.findAll("CartItem", {})
    @serve @html {
      @body {
        @h1 "Cart"
        @ul {
          for item in items {
            @li "{item.handle} / {item.sku} / quantity {item.quantity}"
          }
        }
      }
    }
  }

  @route GET /admin/orders {
    @Auth required role="admin"
    let orders = await shopdb.findAll("Order", {})
    @serve @html {
      @body {
        @h1 "Orders"
        @ul {
          for order in orders {
            @li "#{order.id}: {order.customer} / {order.sku} x {order.quantity} / {order.status}"
          }
        }
      }
    }
  }

  @route GET /admin/payments {
    @Auth required role="admin"
    let payments = await shopdb.findAll("Payment", {})
    @serve @html {
      @body {
        @h1 "Payments"
        @ul {
          for payment in payments {
            @li "#{payment.id}: order {payment.orderId} / {payment.status} / {payment.provider}"
          }
        }
      }
    }
  }

  @route GET /admin/shipments {
    @Auth required role="admin"
    let shipments = await shopdb.findAll("Shipment", {})
    @serve @html {
      @body {
        @h1 "Shipments"
        @ul {
          for shipment in shipments {
            @li "#{shipment.id}: order {shipment.orderId} / {shipment.status} / {shipment.tracking}"
          }
        }
      }
    }
  }

  @route GET /admin/webhooks {
    @Auth required role="admin"
    let webhooks = await shopdb.findAll("WebhookEvent", {})
    @serve @html {
      @body {
        @h1 "Webhooks"
        @ul {
          for webhook in webhooks {
            @li "#{webhook.id}: {webhook.provider} / {webhook.eventId} / {webhook.status}"
          }
        }
      }
    }
  }

  @route GET /admin/audit {
    @Auth required role="admin"
    let auditEvents = await shopdb.findAll("AuditEvent", {})
    @serve @html {
      @body {
        @h1 "Audit Events"
        @ul {
          for auditEvent in auditEvents {
            @li "#{auditEvent.id}: {auditEvent.kind} / {auditEvent.entity} / {auditEvent.status}"
          }
        }
      }
    }
  }

  @route POST /products {
    @csrf
    let price: int = @body.price as int
    let stock: int = @body.stock as int
    let product = await shopdb.create("Product", {
      sku: @body.sku,
      name: @body.name,
      price: price,
      stock: stock
    })
    await shopdb.create("AuditEvent", {
      kind: "product.create",
      entity: "Product",
      entityId: product.id,
      actor: "admin",
      status: "recorded"
    })
    @respond 201 { product: product }
  }

  @route GET /products {
    let products = await shopdb.findAll("Product", {})
    @respond 200 { products: products }
  }

  @route GET /products/:sku {
    let product = await shopdb.find("Product", { sku: @param.sku })
    @respond 200 { product: product }
  }

  @route POST /members {
    @csrf
    let member = await shopdb.create("Member", {
      handle: @body.handle,
      name: @body.name,
      email: @body.email,
      role: "member"
    })
    await shopdb.create("AuditEvent", {
      kind: "member.create",
      entity: "Member",
      entityId: member.id,
      actor: member.handle,
      status: "recorded"
    })
    @respond 201 { member: member }
  }

  @route GET /members/:handle {
    let member = await shopdb.find("Member", { handle: @param.handle })
    @respond 200 { member: member }
  }

  @route POST /members/login {
    @csrf
    let member = await shopdb.find("Member", { handle: @body.handle })
    if member == void {
      @respond 404 { err: "member_not_found", handle: @body.handle }
    }
    if member.email != @body.email {
      @respond 401 { err: "invalid_member_login", handle: @body.handle }
    }
    let session = await shopdb.create("Session", {
      memberId: member.id,
      handle: member.handle,
      status: "active",
      role: member.role ?? "member"
    })
    await shopdb.create("AuditEvent", {
      kind: "session.login",
      entity: "Session",
      entityId: session.id,
      actor: member.handle,
      status: "recorded"
    })
    @respond 201 { session: session, member: member }
  }

  @route POST /cart/items {
    @csrf
    let quantity: int = @body.quantity as int
    let member = await shopdb.find("Member", { handle: @body.handle })
    if member == void {
      @respond 404 { err: "member_not_found", handle: @body.handle }
    }
    let product = await shopdb.find("Product", { sku: @body.sku })
    if product == void {
      @respond 404 { err: "product_not_found", sku: @body.sku }
    }
    if product.stock < quantity {
      @respond 409 { err: "out_of_stock", sku: @body.sku, stock: product.stock }
    }
    let cartItem = await shopdb.create("CartItem", {
      memberId: member.id,
      handle: member.handle,
      sku: @body.sku,
      quantity: quantity,
      status: "active"
    })
    await shopdb.create("AuditEvent", {
      kind: "cart.add",
      entity: "CartItem",
      entityId: cartItem.id,
      actor: member.handle,
      status: "recorded"
    })
    @respond 201 { cartItem: cartItem, member: member, product: product }
  }

  @route POST /orders {
    @csrf
    let quantity: int = @body.quantity as int
    let total: int = @body.total as int
    let product = await shopdb.find("Product", { sku: @body.sku })
    if product == void {
      @respond 404 { err: "product_not_found", sku: @body.sku }
    }
    if product.stock < quantity {
      @respond 409 { err: "out_of_stock", sku: @body.sku, stock: product.stock }
    }
    let remainingStock = product.stock - quantity
    await shopdb.update("Product", { sku: @body.sku }, { stock: remainingStock })
    let order = await shopdb.create("Order", {
      customer: @body.customer,
      sku: @body.sku,
      quantity: quantity,
      total: total,
      status: "reserved"
    })
    await shopdb.create("AuditEvent", {
      kind: "order.reserve",
      entity: "Order",
      entityId: order.id,
      actor: @body.customer,
      status: "recorded"
    })
    @respond 201 { order: order, remainingStock: remainingStock }
  }

  @route GET /orders/:customer {
    let order = await shopdb.find("Order", { customer: @param.customer })
    @respond 200 { order: order }
  }

  @route POST /checkout {
    @csrf
    let quantity: int = @body.quantity as int
    let total: int = @body.total as int
    let member = await shopdb.find("Member", { handle: @body.handle })
    if member == void {
      @respond 404 { err: "member_not_found", handle: @body.handle }
    }
    let product = await shopdb.find("Product", { sku: @body.sku })
    if product == void {
      @respond 404 { err: "product_not_found", sku: @body.sku }
    }
    if product.stock < quantity {
      @respond 409 { err: "out_of_stock", sku: @body.sku, stock: product.stock }
    }
    let remainingStock = product.stock - quantity
    await shopdb.update("Product", { sku: @body.sku }, { stock: remainingStock })
    let order = await shopdb.create("Order", {
      customer: member.handle,
      memberId: member.id,
      sku: @body.sku,
      quantity: quantity,
      total: total,
      status: "reserved"
    })
    let payments = @payment.connect(@env.PAYMENT_ADAPTER_URL ?? "file://data/payments.jsonl")
    let capture = payments.capture({
      orderId: order.id,
      amount: total,
      method: @body.method
    })
    let payment = await shopdb.create("Payment", {
      orderId: capture.orderId,
      amount: capture.amount,
      method: capture.method,
      provider: capture.provider,
      reference: capture.id,
      status: capture.status
    })
    await shopdb.update("Order", { id: order.id }, { status: "paid" })
    let shipping = @shipping.connect(@env.SHIPPING_ADAPTER_URL ?? "file://data/shipments.jsonl")
    let booking = shipping.book({
      orderId: order.id,
      carrier: @body.carrier,
      address: @body.address
    })
    let shipment = await shopdb.create("Shipment", {
      orderId: booking.orderId,
      carrier: booking.carrier,
      address: booking.address,
      provider: booking.provider,
      reference: booking.id,
      status: booking.status,
      tracking: booking.tracking
    })
    await shopdb.update("Order", { id: order.id }, { status: "shipped" })
    let checkoutOrder = await shopdb.find("Order", { id: order.id })
    await shopdb.create("AuditEvent", {
      kind: "checkout.complete",
      entity: "Order",
      entityId: order.id,
      actor: member.handle,
      status: checkoutOrder.status
    })
    await shopdb.create("AuditEvent", {
      kind: "payment.capture",
      entity: "Payment",
      entityId: payment.id,
      actor: member.handle,
      status: payment.status
    })
    await shopdb.create("AuditEvent", {
      kind: "shipment.book",
      entity: "Shipment",
      entityId: shipment.id,
      actor: member.handle,
      status: shipment.status
    })
    @respond 201 {
      order: checkoutOrder,
      payment: payment,
      shipment: shipment,
      member: member,
      remainingStock: remainingStock
    }
  }

  @route POST /payments {
    @csrf
    let orderId: int = @body.orderId as int
    let amount: int = @body.amount as int
    let order = await shopdb.find("Order", { id: orderId })
    if order == void {
      @respond 404 { err: "order_not_found", orderId: orderId }
    }
    if order.total != amount {
      @respond 400 {
        err: "amount_mismatch",
        expected: order.total,
        actual: amount
      }
    }
    let payments = @payment.connect(@env.PAYMENT_ADAPTER_URL ?? "file://data/payments.jsonl")
    let capture = payments.capture({
      orderId: orderId,
      amount: amount,
      method: @body.method
    })
    let payment = await shopdb.create("Payment", {
      orderId: capture.orderId,
      amount: capture.amount,
      method: capture.method,
      provider: capture.provider,
      reference: capture.id,
      status: capture.status
    })
    await shopdb.update("Order", { id: orderId }, { status: "paid" })
    let paidOrder = await shopdb.find("Order", { id: orderId })
    await shopdb.create("AuditEvent", {
      kind: "payment.capture",
      entity: "Payment",
      entityId: payment.id,
      actor: order.customer,
      status: payment.status
    })
    @respond 201 { payment: payment, order: paidOrder }
  }

  @route POST /webhooks/stripe {
    let payments = @payment.connect("stripe://webhook")
    let verification = payments.verifyWebhook({
      payload: @request.rawBody,
      signature: @header["stripe-signature"]
    })
    let eventId = @body.id
    let mut reconciledPayment = void
    let mut reconciledOrder = void
    if verification.status == "verified" {
      if eventId == void {
        let missingIdEvent = await shopdb.create("WebhookEvent", {
          eventId: eventId,
          provider: verification.provider,
          status: "missing_event_id",
          signatureScheme: verification.signatureScheme
        })
        @respond 400 { webhook: missingIdEvent, verification: verification, err: "webhook_event_id_missing" }
      }
      let existing = await shopdb.find("WebhookEvent", {
        provider: verification.provider,
        eventId: eventId
      })
      if existing != void {
        await shopdb.create("AuditEvent", {
          kind: "webhook.duplicate",
          entity: "WebhookEvent",
          entityId: existing.id,
          actor: verification.provider,
          status: existing.status
        })
        @respond 200 { webhook: existing, verification: verification, duplicate: true }
      }
    }
    let event = await shopdb.create("WebhookEvent", {
      eventId: eventId,
      provider: verification.provider,
      status: verification.status,
      signatureScheme: verification.signatureScheme
    })
    await shopdb.create("AuditEvent", {
      kind: "webhook.received",
      entity: "WebhookEvent",
      entityId: event.id,
      actor: verification.provider,
      status: verification.status
    })
    if verification.status != "verified" {
      @respond 400 { webhook: event, verification: verification, duplicate: false }
    }
    let reconcileOrderId = @body["orderId"]
    let reconcilePaymentStatus = @body["paymentStatus"]
    let reconcileOrderStatus = @body["orderStatus"]
    if reconcileOrderId != void {
      let reconciledOrderId: int = reconcileOrderId as int
      if reconcilePaymentStatus != void {
        await shopdb.update("Payment", { orderId: reconciledOrderId }, { status: reconcilePaymentStatus })
        reconciledPayment = await shopdb.find("Payment", { orderId: reconciledOrderId })
      }
      if reconcileOrderStatus != void {
        await shopdb.update("Order", { id: reconciledOrderId }, { status: reconcileOrderStatus })
        reconciledOrder = await shopdb.find("Order", { id: reconciledOrderId })
      }
    }
    @respond 202 {
      webhook: event,
      verification: verification,
      duplicate: false,
      reconciledPayment: reconciledPayment,
      reconciledOrder: reconciledOrder
    }
  }

  @route POST /shipments {
    @csrf
    let orderId: int = @body.orderId as int
    let payment = await shopdb.find("Payment", { orderId: orderId })
    if payment == void {
      @respond 402 { err: "payment_required", orderId: orderId }
    }
    let shipping = @shipping.connect(@env.SHIPPING_ADAPTER_URL ?? "file://data/shipments.jsonl")
    let booking = shipping.book({
      orderId: orderId,
      carrier: @body.carrier,
      address: @body.address
    })
    let shipment = await shopdb.create("Shipment", {
      orderId: booking.orderId,
      carrier: booking.carrier,
      address: booking.address,
      provider: booking.provider,
      reference: booking.id,
      status: booking.status,
      tracking: booking.tracking
    })
    await shopdb.update("Order", { id: orderId }, { status: "shipped" })
    let shippedOrder = await shopdb.find("Order", { id: orderId })
    await shopdb.create("AuditEvent", {
      kind: "shipment.book",
      entity: "Shipment",
      entityId: shipment.id,
      actor: payment.provider,
      status: shipment.status
    })
    @respond 201 { shipment: shipment, order: shippedOrder }
  }

  @route GET /shipments/:orderId {
    let orderId = int.from(@param.orderId)
    let shipment = await shopdb.find("Shipment", { orderId: orderId })
    @respond 200 { shipment: shipment }
  }
}
